{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "panas-rea-metadata.schema.json",
  "title": "PANAS-REA Metadata",
  "type": "object",
  "required": [
    "standard",
    "version",
    "asset_id",
    "title_hash",
    "geo",
    "risk_class",
    "appraisal",
    "vbt",
    "ltv_caps",
    "return_model",
    "covenants"
  ],
  "properties": {
    "standard": { "const": "PANAS-REA" },
    "version": { "type": "string" },
    "asset_id": { "type": "string", "minLength": 3 },
    "title_hash": { "type": "string", "minLength": 16 },
    "geo": {
      "type": "object",
      "required": ["country", "city", "coords"],
      "properties": {
        "country": { "type": "string", "minLength": 2, "maxLength": 3 },
        "city": { "type": "string" },
        "coords": {
          "type": "object",
          "required": ["lat", "lng"],
          "properties": {
            "lat": { "type": "number", "minimum": -90, "maximum": 90 },
            "lng": { "type": "number", "minimum": -180, "maximum": 180 }
          }
        }
      }
    },
    "risk_class": { "enum": ["R0", "R1", "R2", "R3"] },
    "oracles": {
      "type": "object",
      "properties": {
        "valuation": { "type": "string" },
        "legal": { "type": "string" },
        "fx": { "type": "string" },
        "occupancy": { "type": "string" }
      },
      "additionalProperties": false
    },
    "appraisal": {
      "type": "object",
      "required": ["v_inmueble", "v_comparables", "v_local_usdt", "v_plus", "weights"],
      "properties": {
        "v_inmueble": { "type": "number", "minimum": 0 },
        "v_comparables": { "type": "number", "minimum": 0 },
        "v_local_usdt": { "type": "number", "minimum": 0 },
        "v_plus": { "type": "number", "minimum": 0 },
        "weights": {
          "type": "object",
          "required": ["w1", "w2", "w3", "w4"],
          "properties": {
            "w1": { "type": "number", "minimum": 0, "maximum": 1 },
            "w2": { "type": "number", "minimum": 0, "maximum": 1 },
            "w3": { "type": "number", "minimum": 0, "maximum": 1 },
            "w4": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "vbt": { "type": "number", "minimum": 0 },
    "ltv_caps": {
      "type": "object",
      "required": ["regional_cap", "hard_cap"],
      "properties": {
        "regional_cap": { "type": "number", "minimum": 0, "maximum": 1 },
        "hard_cap": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "return_model": {
      "type": "object",
      "required": ["type", "params"],
      "properties": {
        "type": { "enum": ["fixed", "revshare", "pool"] },
        "params": { "type": "object" }
      },
      "additionalProperties": false
    },
    "covenants": {
      "type": "object",
      "required": ["reporting_freq_days"],
      "properties": {
        "reporting_freq_days": { "type": "integer", "minimum": 1 },
        "pool": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "lock_months": { "type": "integer", "minimum": 0 },
            "min_tvl": { "type": "number", "minimum": 0 },
            "slashing_rules": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "hash"],
        "properties": {
          "type": { "type": "string" },
          "hash": { "type": "string" },
          "gps": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 2,
            "maxItems": 2
          },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "governance": {
      "type": "object",
      "properties": {
        "region": { "type": "string" },
        "originator_cap_year": { "type": "number", "minimum": 0 },
        "kyc_level": { "type": "string" }
      },
      "additionalProperties": false
    },
    "links": {
      "type": "object",
      "properties": {
        "docs": { "type": "string" },
        "termsheet": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
